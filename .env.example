POSTGRES_DB=cbt_pulse_grid
POSTGRES_USER=cbt_admin
POSTGRES_PASSWORD=cbt_dev_password
POSTGRES_PORT=5433
POSTGRES_HOST=localhost

BACKEND_PORT=8080
FRONTEND_PORT=5173
FRONTEND_API_BASE_URL=
FRONTEND_WS_URL=/ws

# REST CORS and automatic attempt-expiry processing
REST_CORS_ALLOWED_ORIGINS=http://localhost:5173
ATTEMPT_EXPIRY_SCAN_INTERVAL=10s
ATTEMPT_EXPIRY_BATCH_SIZE=50

JWT_SECRET=cbt-pulse-grid-local-development-secret-2026
JWT_ISSUER=cbt-pulse-grid
JWT_ACCESS_TOKEN_EXPIRY=15m
JWT_REFRESH_TOKEN_EXPIRY=7d

BOOTSTRAP_ADMIN_ENABLED=true
BOOTSTRAP_ADMIN_FORCE_RESET=false
BOOTSTRAP_ADMIN_EMAIL=admin@cbtpulse.local
BOOTSTRAP_ADMIN_PASSWORD=Admin123!

MONITORING_WEBSOCKET_ALLOWED_ORIGINS=http://localhost:5173
MONITORING_HEARTBEAT_SCAN_INTERVAL=10s
MONITORING_HEARTBEAT_TIMEOUT=30s
MONITORING_HEARTBEAT_BATCH_SIZE=100

# Webhooks are disabled until a Base64-encoded 32-byte master key is supplied.
# Generate a private key outside source control, for example: openssl rand -base64 32
WEBHOOK_ENABLED=false
WEBHOOK_MASTER_KEY=<base64-encoded-32-byte-key>
# Development smoke tests only. Never enable this in production.
WEBHOOK_ALLOW_PRIVATE_HTTP=false
WEBHOOK_CONNECT_TIMEOUT=3s
WEBHOOK_RESPONSE_TIMEOUT=5s
WEBHOOK_SCAN_INTERVAL=5s
WEBHOOK_LEASE_DURATION=30s
WEBHOOK_INITIAL_BACKOFF=10s
WEBHOOK_MAXIMUM_BACKOFF=15m
WEBHOOK_BATCH_SIZE=25
WEBHOOK_MAXIMUM_ATTEMPTS=8
